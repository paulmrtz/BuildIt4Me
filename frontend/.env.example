# Development Server
VITE_PORT=5173
VITE_HOST=localhost

# API Configuration
VITE_API_BASE_URL=http://localhost:8000
VITE_API_CHAT_ENDPOINT=/api/chat
VITE_API_HEALTH_ENDPOINT=/api/health

# Application Settings
VITE_APP_NAME=BuildIt4Me
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Mistral AI Chat Application

# Model Defaults
VITE_DEFAULT_MODEL=mistral-tiny
VITE_DEFAULT_TEMPERATURE=0.7
VITE_DEFAULT_MAX_TOKENS=1000

# UI Configuration
VITE_PRIMARY_COLOR=#3b82f6
VITE_SECONDARY_COLOR=#1e40af
VITE_BACKGROUND_COLOR=#f9fafb

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_LOGGING=true

# Development Flags
VITE_DEBUG=false
